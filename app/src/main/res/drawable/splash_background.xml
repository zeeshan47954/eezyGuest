<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color -->
    <item
        android:drawable="@color/teal"/>

    <!-- Centered logo with fixed size -->
    <item
        android:width="130dp"
        android:height="200dp"
        android:top="20dp"
        android:bottom="10dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill_horizontal|fill_vertical"
            android:src="@drawable/applogoreal" />
    </item>
</layer-list>