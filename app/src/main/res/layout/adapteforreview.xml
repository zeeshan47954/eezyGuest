<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reviewCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Row: Profile Image + Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/reviewerImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="5dp"
                android:src="@drawable/graduatingstudent"
                android:background="@drawable/backgroundshape2"
                android:scaleType="centerCrop"
                android:layout_marginEnd="10dp"
                />

            <TextView
                android:id="@+id/reviewer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/teal"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Rating Bar -->
        <RatingBar
            android:id="@+id/rating_bar"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="4.5"
            android:isIndicator="true"
            android:layout_marginTop="6dp"
            android:progressTint="@color/teal" />

        <!-- Review Text -->
        <TextView
            android:id="@+id/review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAlignment="center"
            android:text="Had a great experience! The room was clean and exactly as shown in the photos. Highly recommended!"
            android:textColor="@color/teal"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:padding="4dp" />

        <!-- Optional: Date -->
        <TextView
            android:id="@+id/review_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reviewed on: Oct 7, 2025"
            android:textSize="12sp"

            android:textColor="@color/red"
            android:layout_margin="6dp"
            android:layout_gravity="end" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
