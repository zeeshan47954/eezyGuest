<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <GridLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="16dp"
            android:background="@drawable/gradient_background2">

            <!-- Row 1: Images -->
            <ImageView
                android:id="@+id/roompic1"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <ImageView
                android:id="@+id/roompic2"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <ImageView
                android:id="@+id/roompic3"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <!-- Row 2: Buttons -->
            <Button
                android:id="@+id/roompic1button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/roompic2button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/roompic3button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

            <!-- Row 3: Images -->
            <ImageView
                android:id="@+id/roompic111"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <ImageView
                android:id="@+id/roompic222"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <ImageView
                android:id="@+id/roompic333"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:src="@drawable/roompic"
                android:layout_gravity="fill_horizontal"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:adjustViewBounds="true" />

            <!-- Row 4: Buttons -->
            <Button
                android:id="@+id/roompic111button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="3"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/roompic222button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="3"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/roompic333button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="fill_horizontal"
                android:layout_row="3"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@drawable/fancy_button_background"
                android:text="Choose"
                android:textColor="@color/white" />

        </GridLayout>

        <Button
            android:id="@+id/addMoreButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:background="@drawable/fancy_button_background"
            android:text="Add More"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/Submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:background="@drawable/fancy_button_background"
            android:text="Submit"
            android:onClick="submit"
            android:textColor="@color/white" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>