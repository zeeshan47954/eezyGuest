<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:background="@color/teal"
    android:layout_height="match_parent"
    tools:context=".roominfoandbookfinal2"
    >

    <!-- AppBar with CollapsingToolbarLayout -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:id="@+id/abl"
        android:theme="@style/ThemeOverlay.AppCompat.DayNight"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/ct"
            app:titleTextColor="@color/teal"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="?attr/colorPrimary">



            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/imageSlider"
                android:layout_width="match_parent"
                android:layout_height="300dp"

                app:layout_collapseMode="parallax"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center"
                android:orientation="horizontal">

                <!-- Dots Indicator -->
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_gravity="bottom|center"
                    android:src="@drawable/arrowleft"
                    />
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/dotsIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="10dp"
                    android:layout_gravity="bottom|center"

                    app:tabBackground="@drawable/tab_selector"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="10dp"
                    app:tabMinWidth="10dp"/>

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_gravity="bottom|center"
                    android:src="@drawable/arrowright"
                    />
                <!-- ViewPager2 for sliding images -->
            </LinearLayout>
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/tb"
                app:titleTextColor="@color/teal"
                android:layout_width="wrap_content"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>



    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content Scrollable Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"

        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical"
            android:padding="16dp">

            <!-- Room Name Card -->

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fancy_button_background"
                android:layout_gravity="end"
                android:text="leave room "
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:id="@+id/leavebutton"
                android:onClick="leaveroom"
                android:textColor="@color/white"
                android:drawableRight="@drawable/exitroom"/>
            <TextView
                android:id="@+id/roomname"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:layout_marginTop="20dp"
                android:textAlignment="center"
                android:background="@drawable/fancy_text_background"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold" />



            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:elevation="6dp"
                android:padding="10dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/teal"
                        android:textStyle="bold"
                        android:text="Owner Details"
                        android:textSize="25sp" />
                    <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="300dp"
                            android:layout_height="300dp"

                            android:scaleType="centerCrop"
                        android:layout_gravity="center"

                            android:background="#CCCCCC" />

                        <!-- Info Section -->


                            <!-- Name -->
                            <TextView
                                android:id="@+id/labelName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Name"
                                android:layout_marginLeft="16dp"

                                android:textSize="14sp"
                                android:textColor="@color/teal" />

                            <TextView
                                android:id="@+id/valueName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="John Doe"
                                android:textSize="18sp"
                                android:layout_marginLeft="16dp"
                                android:textColor="@color/red"
                                android:textStyle="bold"
                                android:layout_marginBottom="12dp" />

                            <!-- Address -->
                            <TextView
                                android:id="@+id/labelAddress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Address"
                                android:textSize="14sp"
                                android:layout_marginLeft="16dp"
                                android:textColor="@color/teal" />

                            <TextView
                                android:id="@+id/valueAddress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="123 Main Street, City"
                                android:textSize="16sp"
                                android:layout_marginLeft="16dp"
                                android:textColor="@color/red"
                                android:layout_marginBottom="12dp" />

                            <!-- Phone -->
                            <TextView
                                android:id="@+id/labelPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact no"
                                android:layout_marginLeft="16dp"
                                android:textSize="14sp"
                                android:textColor="@color/teal" />

                            <TextView
                                android:id="@+id/valuePhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+91 9876543210"
                                android:layout_marginLeft="16dp"
                                android:textSize="16sp"
                                android:textColor="@color/red" />


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Room Information Header Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:layout_marginTop="20dp"
                android:textAlignment="center"
                android:layout_gravity="center
"
                android:background="@drawable/fancy_text_background"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:text="Room location and information" />


            <!-- Room Address Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="room address:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/roomlocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Room Type Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="room type:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/roomtype"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- District Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="district:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/roomdistrict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Current Occupants Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="current occupants:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/occupants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Room Capacity Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/capacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="total room capacity:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Remaining Capacity Card -->

            <!-- Room Price Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="room price:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="room coordinates:"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:textSize="17dp"
                        android:textAlignment="center"
                        android:textColor="@color/teal" />

                    <TextView
                        android:id="@+id/coordinates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="text"
                        android:textColor="@color/red" />
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="copy"
                        android:layout_gravity="right"
                        android:id="@+id/copy"
                        android:background="@drawable/copy2"
                        android:src="@drawable/copy2"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="click the location button to view the full roomlocation,or you can just copy the coordinates paste them into googlemaps"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="10dp"
                android:textColor="@color/teal"
                android:textSize="17dp"
                android:textAlignment="center"/>


            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="10dp"
                app:cardElevation="8dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                android:onClick="showmap"
                app:cardBackgroundColor="@color/white">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/location"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textColor="@color/teal"
                        android:textSize="12sp"/>
                </LinearLayout>


            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                <!-- Facilities Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_header_bg"
                    android:text="Facilities"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:elevation="4dp" />

                <!-- Facilities Content -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Spacious rooms, WiFi, 24x7 water..."
                        android:textColor="@color/teal"
                        android:textSize="16sp" />
                </androidx.cardview.widget.CardView>

                <!-- Rules Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/rules"
                    android:text="Rules"
                    android:layout_gravity="center"
                    android:textColor="@color/white"
                    android:textSize="20sp"

                    android:textStyle="bold"
                    android:elevation="4dp" />

                <!-- Rules Content -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <TextView
                        android:id="@+id/textView3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="No smoking, No loud music, Visitors till 8PM..."
                        android:textColor="@color/teal"
                        android:textSize="16sp" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

<Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
    android:layout_margin="20dp"
    android:text="Leave a review"
    android:onClick="review"
    android:padding="3dp"
    android:textColor="@color/white"
    android:background="@drawable/fancy_button_background"/>
            <!-- CardView and Button Section -->


                <!-- Location Button -->

                <!-- Push Button to End -->



        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
