<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/teal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_marginTop="5dp"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/tbmain"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Room and Owner Information"
            app:titleTextColor="@color/white"
            app:layout_scrollFlags="scroll|enterAlways"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardCornerRadius="8dp"

                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"

                    android:padding="16dp">




                    <TextView
                        android:id="@+id/location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:textStyle="bold"
                        android:hint="room details:"
                        android:textColorHint="@color/teal"
                        android:textSize="20sp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:padding="10dp"
                    android:orientation="vertical">
                    <EditText
                        android:id="@+id/roomname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:padding="5dp"
                        android:textColor="@color/teal"
                        android:hint="room name/hostel name"
                        android:overScrollMode="always"

                        android:inputType="textMultiLine"
                        android:textColorHint="@color/teal" />
                    <EditText
                        android:id="@+id/institution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter the nearest college/university"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="textMultiLine"

                        android:textColor="@color/teal"
                        android:textColorHint="@color/teal" />
                    <EditText
                        android:id="@+id/roomlocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="room address"
                        android:textColor="@color/teal"
                        android:background="@drawable/backgroundshape2"
                        android:padding="5dp"
                        android:overScrollMode="always"

                        android:inputType="textMultiLine"
                        android:textColorHint="@color/teal" />


                    <EditText
                        android:id="@+id/roompricing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="room price per head"
                        android:inputType="number"
                        android:background="@drawable/backgroundshape2"
                        android:padding="5dp"
                        android:textColor="@color/teal"


                        android:textColorHint="@color/teal" />

                    <EditText
                        android:id="@+id/roomcapacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="room capacity"
                        android:inputType="number"
                        android:background="@drawable/backgroundshape2"
                        android:padding="5dp"
                        android:textColor="@color/teal"


                        android:textColorHint="@color/teal" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="district:"

                        android:textColorHint="@color/teal"
                        android:textSize="20sp" />

                    <Spinner
                        android:id="@+id/spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Room coordinates:"
                        android:textColor="@color/teal"

                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:textColor="@color/red"
                        />

                    <EditText
                        android:id="@+id/latitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="latitude"
                        android:inputType="numberDecimal"
                        android:maxLength="10"
                        android:background="@drawable/backgroundshape2"
                        android:textColorHint="@color/teal"
                        android:textColor="@color/teal"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/longitude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="longitude"
                        android:textColor="@color/teal"
                        android:background="@drawable/backgroundshape2"
                        android:inputType="numberDecimal"
                        android:maxLength="10"
                        android:textColorHint="@color/teal"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <androidx.cardview.widget.CardView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:id="@+id/mapcv"
                            android:layout_margin="20dp"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            app:cardElevation="8dp"
                            android:onClick="showmap"
                            app:cardCornerRadius="4dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginBottom="10dp"
                                android:src="@drawable/location"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:layout_gravity="center|bottom"
                                android:text="location"
                                android:textColor="@color/teal"/>
                        </androidx.cardview.widget.CardView>

                        <Button
                            android:id="@+id/manual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:background="@drawable/fancy_button_background"
                            android:onClick="showcoordinatesformanual"
                            android:padding="5dp"
                            android:textColor="@color/nav_item_color"
                            android:text="enter manually"
                            android:textAlignment="center"
                            />

                        <Button
                            android:id="@+id/automatic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fancy_button_background"
                            android:onClick="showcoordinatesforapp"
                            android:padding="5dp"
                            android:text="let the app do it"
                            android:textColor="@color/white" />

                    </LinearLayout>


                    <RadioGroup
                        android:id="@+id/radioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Room Type:"

                            android:textColor="@color/teal"
                            android:textSize="16sp" />

                        <RadioButton
                            android:id="@+id/radioButton1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="16dp"
                            android:layout_gravity="center"
                            android:buttonTint="@color/teal"
                            android:text="PG"
                            android:textColor="@color/teal" />

                        <RadioButton
                            android:id="@+id/radioButton2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="1dp"
                            android:layout_gravity="center"
                            android:buttonTint="@color/teal"
                            android:text="Non-PG"
                            android:textColor="@color/teal" />

                    </RadioGroup>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:padding="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Room Facilities:"
                        android:textColor="@color/teal"
                        android:textSize="20dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="1.add one facility\n2.hit 'add facility' button\n3.continue the process to add the remaining facilities\n*this way you can also remove facilities"
                        android:textColor="@color/teal"
                        android:textSize="15dp" />

                    <LinearLayout

                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <EditText
                            android:id="@+id/facility_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="add room facility one by one"
                            android:background="@drawable/backgroundshape2"
                            android:overScrollMode="always"

                            android:inputType="textMultiLine"
                            android:textColor="@color/teal"
                            android:textColorHint="@color/teal" />

                        <Button
                            android:id="@+id/add_facility_button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/fancy_button_background"
                            android:text="Add Facility"
                            android:textColor="@color/white" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/facility_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>
                    <LinearLayout

                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" House Rules: "
                            android:textSize="20dp"


                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp"
                            android:textColor="@color/teal"/>
                        <EditText
                            android:id="@+id/rules_input"
                            android:hint=" add house rules"
                            android:layout_width="match_parent"
                            android:textColorHint="@color/teal"
                            android:textColor="@color/teal"
                            android:overScrollMode="always"

                            android:inputType="textMultiLine"
                            android:background="@drawable/backgroundshape2"


                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"/>

                        <Button
                            android:id="@+id/add_rules_button"
                            android:text="Add Rule"
                            android:background="@drawable/fancy_button_background"
                            android:layout_width="match_parent"
                            android:textColor="@color/white"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rules_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>



                    <TextView
                        android:id="@+id/errors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#64140A"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/submitbutton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/fancy_button_background"
                        android:onClick="submit"
                        android:text="submit"
                        android:textColor="@color/white" />


                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>